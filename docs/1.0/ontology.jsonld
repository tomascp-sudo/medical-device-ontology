    "@value" : "published"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Ontology about medical devices, their classification, incidents, risks and corrective actions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Medical Devices Classification and Safety Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://tomascp-sudo.github.io/medical-device-ontology/1.0/ontology.owl"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "Version 1.0"
  } ],
  "https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#schma:includedInDataCatalog" : [ {
    "@value" : "This ontology is about medical devices, their classification, and the safety mechanisms associated with their use, including incidents and corrective actions."
  } ],
