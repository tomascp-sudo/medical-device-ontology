@prefix : <http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#> .

<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology> rdf:type owl:Ontology ;
                                                                owl:versionIRI <https://tomascp-sudo.github.io/medical-device-ontology/1.0/ontology.owl> ;
                                                                <http://purl.org/dc/elements/1.1/description> "Ontology for representing medical devices, manufacturers, incidents, risks and corrective actions in regulatory surveillance scenarios." ,
                                                                                                              "This ontology models relationships between devices, manufacturers, risks, incidents and field safety corrective actions (FSCA), enabling integrated regulatory surveillance within a single semantic framework." ;
                                                                <http://purl.org/dc/elements/1.1/title> "EUDAMED-Inspired Medical Device Ontology" ;
                                                                <http://purl.org/dc/terms/abstract> "This ontology provides a semantic model for high-risk medical devices and in vitro diagnostic devices, including their manufacturers, risk classes, incidents, and field safety corrective actions. It supports formal knowledge representation, reasoning, and interoperability in regulatory surveillance scenarios under MDR and IVDR frameworks." ;
                                                                <http://purl.org/dc/terms/creator> "Diana Socola"@en ,
                                                                                                   "Tomás Cuevas"@en ;
                                                                <http://purl.org/dc/terms/license> "https://creativecommons.org/licenses/by-sa/4.0/" ;
                                                                rdfs:comment "Ontology about medical devices, their classification, incidents, risks and corrective actions." ;
                                                                rdfs:isDefinedBy """The authors of this ontology have been:

Diana Alejandrina Socola

Tomás Cuevas""" ;
                                                                rdfs:label "Medical Devices Classification and Safety Ontology"@en ;
                                                                owl:versionInfo "Version 1.0" ;
                                                                <https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#schma:includedInDataCatalog> "This ontology is about medical devices, their classification, and the safety mechanisms associated with their use, including incidents and corrective actions." ;
                                                                <https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#terms:created> "2026-04-21T00:30"^^xsd:date ;
                                                                <https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#vann:preferredNamespacePrefix> "EUDAMED" ;
                                                                <https://w3id.org/mod#createdWith> <https://chowlk.linkeddata.es/> ,
                                                                                                   "https://chowlk.linkeddata.es/" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/abstract
<http://purl.org/dc/terms/abstract> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#comment
rdfs:comment rdf:type owl:AnnotationProperty .


###  https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#schma:includedInDataCatalog
<https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#schma:includedInDataCatalog> rdf:type owl:AnnotationProperty .


###  https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#terms:created
<https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#terms:created> rdf:type owl:AnnotationProperty .


###  https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#vann:preferredNamespacePrefix
<https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#vann:preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  https://w3id.org/mod#createdWith
<https://w3id.org/mod#createdWith> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#actionIssuedBy
:actionIssuedBy rdf:type owl:ObjectProperty ;
                rdfs:domain :CorrectiveAction ;
                rdfs:range :Manufacturer ;
                rdfs:comment "Relates a corrective action to the manufacturer that issued it"@en ;
                rdfs:label "actionIssuedBy"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#addressesIncident
:addressesIncident rdf:type owl:ObjectProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range :Incident ;
                   rdfs:comment "Relates a corrective action to the incident it addresses."@en ;
                   rdfs:label "addresses incident"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#affectsDevice
:affectsDevice rdf:type owl:ObjectProperty ;
               rdfs:domain :Incident ;
               rdfs:range :Device ;
               rdfs:comment "Relates an incident to the device involved."@en ;
               rdfs:label "affects device"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#harRiskClass
:harRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :risk_class ;
              rdfs:comment "Relates a device to its risk classification."@en ;
              rdfs:label "har risk class"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasActionType
:hasActionType rdf:type owl:ObjectProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range :action_type ;
               rdfs:comment "Relates a corrective action to its action type."@en ;
               rdfs:label "has action type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasCategory
:hasCategory rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :risk_category ;
             rdfs:comment "Associates a risk with its specific category"@en ;
             rdfs:label "has category" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ;
               rdfs:domain :Device ;
               rdfs:range :device_type ;
               rdfs:comment "Relates a device to its device type."@en ;
               rdfs:label "has device type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasIncidentType
:hasIncidentType rdf:type owl:ObjectProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :incident_type ;
                 rdfs:comment "Relates an incident to its incident type."@en ;
                 rdfs:label "has incident type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Relates a device to its manufacturer."@en ;
                 rdfs:label "has manufacturer"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasProbability
:hasProbability rdf:type owl:ObjectProperty ;
                rdfs:domain :Risk ;
                rdfs:range :probability ;
                rdfs:comment "Relates a risk to its probability level."@en ;
                rdfs:label "has probability"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasRegulatoryFramework
:hasRegulatoryFramework rdf:type owl:ObjectProperty ;
                        rdfs:domain :Device ;
                        rdfs:range :regulatory_framework ;
                        rdfs:comment "Relates a device to its regulatory framework."@en ;
                        rdfs:label "has regulatory framework"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasRisk
:hasRisk rdf:type owl:ObjectProperty ;
         rdfs:domain :Incident ;
         rdfs:range :Risk ;
         rdfs:comment "Relates an incident to an identified risk"@en ;
         rdfs:label "has risk"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasSeverity
:hasSeverity rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :severity ;
             rdfs:comment "Relates a risk to its severity level."@en ;
             rdfs:label "has severity"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasStatus
:hasStatus rdf:type owl:ObjectProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range :status ;
           rdfs:comment "Relates a corrective action to its current status."@en ;
           rdfs:label "has status"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasType
:hasType rdf:type owl:ObjectProperty ;
         rdfs:domain :Risk ;
         rdfs:range :risk_type ;
         rdfs:comment "Relates a risk type to its current risk."@en ;
         rdfs:label "has type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Relates a manufacturer  who was reported an incident"@en ;
            rdfs:label "reported by"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#action_date
:action_date rdf:type owl:DatatypeProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:date ;
             rdfs:comment "Specifies the date on which a corrective action was initiated."@en ;
             rdfs:label "action_date"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#authorization_number
:authorization_number rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Manufacturer ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Specifies the authorization number assigned to a manufacturer."@en ;
                      rdfs:label "authorization_number"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#closure_date
:closure_date rdf:type owl:DatatypeProperty ;
              rdfs:domain :CorrectiveAction ;
              rdfs:range xsd:date ;
              rdfs:comment "Specifies the date on which a corrective action was closed."@en ;
              rdfs:label "closure_date"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#competent_authority
:competent_authority rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Specifies the competent authority responsable for a manufacturer."@en ;
                     rdfs:label "competent_authority"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#contact_email
:contact_email rdf:type owl:DatatypeProperty ;
               rdfs:domain :Manufacturer ;
               rdfs:range xsd:string ;
               rdfs:comment "Specifies the email assigned to a manufacturer."@en ;
               rdfs:label "contact_email"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#correctiveActionDescription
:correctiveActionDescription rdf:type owl:DatatypeProperty ;
                             rdfs:domain :CorrectiveAction ;
                             rdfs:range xsd:string ;
                             rdfs:comment "Provides a textual description of the corrective action."@en ;
                             rdfs:label "correctiveActionDescription"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#corrective_action_taken
:corrective_action_taken rdf:type owl:DatatypeProperty ;
                         rdfs:domain :Incident ;
                         rdfs:range xsd:boolean ;
                         rdfs:comment "Indicates whether a corrective action has been taken for an incident."@en ;
                         rdfs:label "corrective_action_taken"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#countries_affected
:countries_affected rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Specifies the country on which a corrective action was declared."@en ;
                    rdfs:label "countries_affected"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#country
:country rdf:type owl:DatatypeProperty ;
         rdfs:domain :Manufacturer ;
         rdfs:range xsd:string ;
         rdfs:comment "Specifies the country where a manufacturer is located"@en ;
         rdfs:label "country"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#country_report
:country_report rdf:type owl:DatatypeProperty ;
                rdfs:domain :Incident ;
                rdfs:range xsd:string ;
                rdfs:comment "Specifies the country in which an incident was reported."@en ;
                rdfs:label "country_report"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#detection_date
:detection_date rdf:type owl:DatatypeProperty ;
                rdfs:domain :Incident ;
                rdfs:range xsd:date ;
                rdfs:comment "Specifies the date on which an incident was detected."@en ;
                rdfs:label "detection_date"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#device_id
:device_id rdf:type owl:DatatypeProperty ;
           rdfs:domain :Device ;
           rdfs:range xsd:string ;
           rdfs:comment "Specifies the commercial id of a device"@en ;
           rdfs:label "device_id"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#device_name
:device_name rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:string ;
             rdfs:comment "Specifies the commercial name of a device."@en ;
             rdfs:label "device_name"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#devices_affected
:devices_affected rdf:type owl:DatatypeProperty ;
                  rdfs:domain :CorrectiveAction ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "Specifies the number of devices affected by a corrective action."@en ;
                  rdfs:label "devices_affected"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#eudamed_fsca_ref
:eudamed_fsca_ref rdf:type owl:DatatypeProperty ;
                  rdfs:domain :CorrectiveAction ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Specifies the EUDAMED reference identifier of a field safety corrective action."@en ;
                  rdfs:label "eudamed_fsca_ref"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#eudamed_incident_ref
:eudamed_incident_ref rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Incident ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Specifies the EUDAMED reference identifier of an incident."@en ;
                      rdfs:label "eudamed_incident_ref"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#eudamed_srn
:eudamed_srn rdf:type owl:DatatypeProperty ;
             rdfs:domain :Manufacturer ;
             rdfs:range xsd:string ;
             rdfs:comment "Specifies the Single Registration Number assigned in EUDAMED."@en ;
             rdfs:label "eudamed_srn"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#event_date
:event_date rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "Specifies the date on which an incident occurred."@en ;
            rdfs:label "event_date"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#fsca_id
:fsca_id rdf:type owl:DatatypeProperty ;
         rdfs:domain :CorrectiveAction ;
         rdfs:range xsd:string ;
         rdfs:comment "Specifies the  identifier of a corrective action."@en ;
         rdfs:label "fsca_id"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#imdrs_code
:imdrs_code rdf:type owl:DatatypeProperty ;
            rdfs:domain :Risk ;
            rdfs:range xsd:string ;
            rdfs:comment "Specifies the IMDRF code assigned to a risk."@en ;
            rdfs:label "imdrs_code"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#incidentDescription
:incidentDescription rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Provides a textual description of an incident."@en ;
                     rdfs:label "incidentDescription"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#incident_id
:incident_id rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:string ;
             rdfs:comment "A unique identifier for an incident report"@en ;
             rdfs:label "incident_id" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#intended_purpose
:intended_purpose rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Device ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Specifies the intended purpose of a medical device."@en ;
                  rdfs:label "intended_purpose"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#is_active
:is_active rdf:type owl:DatatypeProperty ;
           rdfs:domain :Device ;
           rdfs:range xsd:boolean ;
           rdfs:comment "Specifies the status of a medical device."@en ;
           rdfs:label "is_active"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#is_implantable
:is_implantable rdf:type owl:DatatypeProperty ;
                rdfs:domain :Device ;
                rdfs:range xsd:boolean ;
                rdfs:comment "Specifies whether  a medical device is implantable."@en ;
                rdfs:label "is_implantable" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#is_ivd
:is_ivd rdf:type owl:DatatypeProperty ;
        rdfs:domain :Device ;
        rdfs:range xsd:boolean ;
        rdfs:comment "Inidcates whether a medical device in in vitro diagnostic device."@en ;
        rdfs:label "is_ivd"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#is_reusable
:is_reusable rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Indicates whether a medical device is reusable."@en ;
             rdfs:label "is_reusable"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#manufacturer_id
:manufacturer_id rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Manufacturer ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Specifies the identifier assigned to a manufacturer."@en ;
                 rdfs:label "manufacturer_id"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#name
:name rdf:type owl:DatatypeProperty ;
      rdfs:domain :Manufacturer ;
      rdfs:range xsd:string ;
      rdfs:comment "Specifies the name of a manufacturer"@en ;
      rdfs:label "name"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#outcome
:outcome rdf:type owl:DatatypeProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "Specifies the outcome of an incident."@en ;
         rdfs:label "outcome"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#patient_age
:patient_age rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:integer ;
             rdfs:comment "Specifies the age of the patient involved in an incident."@en ;
             rdfs:label "patient_age"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#patient_sex
:patient_sex rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:string ;
             rdfs:comment "Specifies the sex of the patient involved in an incident."@en ;
             rdfs:label "patient_sex"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#report_date
:report_date rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:date ;
             rdfs:comment "Specifies the datum of the  an incident was reported."@en ;
             rdfs:label "report_date"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#reporting_entity
:reporting_entity rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Incident ;
                  rdfs:range xsd:string ;
                  rdfs:comment "describe the manufacturer who repoted incident"@en ;
                  rdfs:label "reporting_entity"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#requiresImplantCard
:requiresImplantCard rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Device ;
                     rdfs:range xsd:boolean ;
                     rdfs:comment "a special survel property"@en ;
                     rdfs:label "requiresImplantCard"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#requiresUrgentReview
:requiresUrgentReview rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Incident ;
                      rdfs:range xsd:boolean ;
                      rdfs:comment "if an incident has a high risk and serous then requiresUrgentReview"@en ;
                      rdfs:label "requiresUrgentReview"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#riskDescription
:riskDescription rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Provides a textual description of a risk."@en ;
                 rdfs:label "riskDescription"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#risk_id
:risk_id rdf:type owl:DatatypeProperty ;
         rdfs:domain :Risk ;
         rdfs:range xsd:string ;
         rdfs:comment "Specifies the identifier assigned to a risk."@en ;
         rdfs:label "risk_id"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#risk_name
:risk_name rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "describe the name assigned to a risk"@en ;
           rdfs:label "risk_name"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#scope
:scope rdf:type owl:DatatypeProperty ;
       rdfs:domain :CorrectiveAction ;
       rdfs:range xsd:string ;
       rdfs:comment "Specifies the scope of a corrective action."@en ;
       rdfs:label "scope"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#udi:di
:udi:di rdf:type owl:DatatypeProperty ;
        rdfs:domain :Device ;
        rdfs:range xsd:string ;
        rdfs:comment "Specifies the Device Identifier part of the Unique Device Identification code"@en ;
        rdfs:label "udi:di"@en .


#################################################################
#    Classes
#################################################################

###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :device_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :device_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassC
:ClassC rdf:type owl:Class ;
        rdfs:subClassOf :risk_class .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassD
:ClassD rdf:type owl:Class ;
        rdfs:subClassOf :risk_class .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :risk_class .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :risk_class .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :risk_class .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Closed
:Closed rdf:type owl:Class ;
        rdfs:subClassOf :status ;
        owl:disjointWith :Open .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :fsca_id ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :action_date ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :closure_date ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :correctiveActionDescription ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :countries_affected ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :devices_affected ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:integer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :eudamed_fsca_ref ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :scope ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ;
                  rdfs:comment "Action taken by the manufacturer to eliminate the cause of a detected nonconformity or other undesirable situation related to a medical device, including field safety corrective actions."@en ;
                  rdfs:label "Corrective Action"@en ;
                  rdfs:seeAlso "https://dbpedia.org/describe/?url=http%3A%2F%2Fdbpedia.org%2Fresource%2FCorrective_and_preventive_action&sid=7760" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :device_id ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :device_name ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :intended_purpose ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_active ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_implantable ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_ivd ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :is_reusable ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :udi:di ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ;
        rdfs:comment "Products or equipment intended for a medical purpose. In the EU, they must undergo a conformity assessment to demonstrate they meet legal requirements to ensure they are safe and perform as intended."@en ;
        rdfs:label "Device"@en ;
        rdfs:seeAlso "https://op.europa.eu/web/eu-vocabularies/concept/-/resource?uri=http://data.europa.eu/uxp/3844" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DeviceFailure
:DeviceFailure rdf:type owl:Class ;
               rdfs:subClassOf :risk_category .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DevicePerformance
:DevicePerformance rdf:type owl:Class ;
                   rdfs:subClassOf :risk_category .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DeviceSafety
:DeviceSafety rdf:type owl:Class ;
              rdfs:subClassOf :risk_category .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DiagnosticError
:DiagnosticError rdf:type owl:Class ;
                 rdfs:subClassOf :risk_category .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#HighRiskImplantableDevice
:HighRiskImplantableDevice rdf:type owl:Class ;
                           owl:equivalentClass [ owl:intersectionOf ( :Device
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :harRiskClass ;
                                                                        owl:hasValue :ClassIII
                                                                      ]
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty :hasDeviceType ;
                                                                        owl:hasValue :ImplantableDevice
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ] ;
                           rdfs:subClassOf :Device ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :device_id ;
                                             owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:string
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :device_name ;
                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:string
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :intended_purpose ;
                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:string
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :is_active ;
                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:boolean
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :is_implantable ;
                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:boolean
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :is_ivd ;
                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:boolean
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :is_reusable ;
                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:boolean
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty :udi:di ;
                                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                             owl:onDataRange xsd:string
                                           ] ;
                           rdfs:comment "Any device that meets those conditions will be automatically inferred to be a HighRiskImplantableDevice"@en ;
                           rdfs:label "HighRiskImplantableDevice"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#HighRiskIncident
:HighRiskIncident rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( :Incident
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty :hasRisk ;
                                                               owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                           owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                                                           owl:onProperty :hasProbability ;
                                                                                                                           owl:hasValue :high
                                                                                                                         ]
                                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                                           owl:onProperty :hasProbability ;
                                                                                                                           owl:hasValue :medium
                                                                                                                         ]
                                                                                                                       )
                                                                                                         ]
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty :hasSeverity ;
                                                                                                           owl:hasValue :serious
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ]
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf :Incident ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :incident_id ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :correctiveActionDescription ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :corrective_action_taken ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:boolean
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :country_report ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :detection_date ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :eudamed_incident_ref ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :event_date ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :outcome ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :patient_age ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:integer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :patient_sex ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :report_date ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:date
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty :reporting_entity ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] ;
                  rdfs:comment "Any incident that meets those conditions will be automatically inferred to be a HighRiskIncident"@en ;
                  rdfs:label "HighRiskIncident"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#IVDR
:IVDR rdf:type owl:Class ;
      rdfs:subClassOf :regulatory_framework ;
      owl:disjointWith :MDR .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :device_type ;
                         owl:disjointWith :InVitroDiagnosticDevice ,
                                          :SelfTestDevice ,
                                          :SingleUseDevice .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :device_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :action_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :device_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :incident_id ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :correctiveActionDescription ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :corrective_action_taken ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:boolean
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :country_report ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :detection_date ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :eudamed_incident_ref ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :event_date ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :outcome ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :patient_age ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:integer
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :patient_sex ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :report_date ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reporting_entity ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ;
          rdfs:comment "Any malfunction or deterioration in the characteristics or performance of a device, or any inadequacy in the information supplied by the manufacturer, or any undesirable side-effect, that has or could have led to harm to a patient, user or other person."@en ;
          rdfs:label "Incident"@en ;
          rdfs:seeAlso "http://purl.bioontology.org/ontology/SNOMEDCT/405533003" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#MDR
:MDR rdf:type owl:Class ;
     rdfs:subClassOf :regulatory_framework .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :manufacturer_id ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :name ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :authorization_number ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :competent_authority ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :contact_email ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :country ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :eudamed_srn ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:comment "The natural or legal person who manufactures or fully refurbishes a device or has a device designed, manufactured or fully refurbished, and markets that device under its name or trademark."@en ;
              rdfs:label "Manufacturer"@en ;
              rdfs:seeAlso "https://browser.ihtsdotools.org/?perspective=full&conceptId1=43309009&edition=MAIN&release=&languages=en" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :incident_type ;
                  owl:disjointWith :SeriousIncident .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Open
:Open rdf:type owl:Class ;
      rdfs:subClassOf :status .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#PatientHarm
:PatientHarm rdf:type owl:Class ;
             rdfs:subClassOf :risk_category .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ProductQuality
:ProductQuality rdf:type owl:Class ;
                rdfs:subClassOf :risk_category .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :action_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#RecallCorrectiveAction
:RecallCorrectiveAction rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( :CorrectiveAction
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty :hasActionType ;
                                                                     owl:hasValue :Recall
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf :CorrectiveAction ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :hasActionType ;
                                          owl:hasValue :Recall
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :fsca_id ;
                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :action_date ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:date
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :closure_date ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:date
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :correctiveActionDescription ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :countries_affected ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :devices_affected ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:integer
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :eudamed_fsca_ref ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :scope ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:string
                                        ] ;
                        rdfs:comment "Represents a corrective action categorized as a recall."@en ;
                        rdfs:label "RecallCorrectiveAction"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :risk_id ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :imdrs_code ;
                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :riskDescription ;
                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :risk_name ;
                        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ;
      rdfs:comment "Combination of the probability of occurrence of harm and the severity of that harm. This concept is central to the risk management process required for medical devices under the MDR and IVDR."@en ;
      rdfs:label "Risk"@en ;
      rdfs:seeAlso "https://snomedsns.es/search/405142001" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :action_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :device_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :incident_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :device_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :risk_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :action_type .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#action_type
:action_type rdf:type owl:Class ;
             rdfs:comment "Type of corrective or preventive action taken by the manufacturer in response to a medical device incident or risk."@en ;
             rdfs:label "action_type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#critical
:critical rdf:type owl:Class ;
          rdfs:subClassOf :severity .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#device_type
:device_type rdf:type owl:Class ;
             rdfs:comment "Represents the type of medical device."@en ;
             rdfs:label "device_type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#high
:high rdf:type owl:Class ;
      rdfs:subClassOf :probability .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#incident_type
:incident_type rdf:type owl:Class ;
               rdfs:comment "Represents the type of incident associated with a medical device."@en ;
               rdfs:label "incident_type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#low
:low rdf:type owl:Class ;
     rdfs:subClassOf :probability .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#medium
:medium rdf:type owl:Class ;
        rdfs:subClassOf :probability .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#moderate
:moderate rdf:type owl:Class ;
          rdfs:subClassOf :severity .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#probability
:probability rdf:type owl:Class ;
             rdfs:comment "Estimate of the likelihood of occurrence of harm associated with a hazard or risk in the context of medical device risk management." ;
             rdfs:label "probability" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#regulatory_framework
:regulatory_framework rdf:type owl:Class ;
                      rdfs:comment "The applicable European Union legal framework for medical devices, primarily Regulation (EU) 2017/745 (MDR) or Regulation (EU) 2017/746 (IVDR)."@en ;
                      rdfs:label "regulatory_framework"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#risk_category
:risk_category rdf:type owl:Class ;
               rdfs:comment "represents the risk category applicable in the European Union"@en ;
               rdfs:label "risk_category"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#risk_class
:risk_class rdf:type owl:Class ;
            rdfs:comment "Classification of a medical device according to its inherent risk level as defined in Annex VIII of the MDR or Annex VIII of the IVDR."@en ;
            rdfs:label "risk_class"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#risk_type
:risk_type rdf:type owl:Class ;
           rdfs:comment "Classification of the nature or source of a risk associated with the use or failure of a medical device."@en ;
           rdfs:label "risk_type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#serious
:serious rdf:type owl:Class ;
         rdfs:subClassOf :severity .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#severity
:severity rdf:type owl:Class ;
          rdfs:comment "Measure of the possible consequences of a hazard or risk on the health of patients, users or other persons." ;
          rdfs:label "severity" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#status
:status rdf:type owl:Class ;
        rdfs:comment "Represents a  status for a corrective action"@en ;
        rdfs:label "status"@en .


