#################################################################
#    Rules
#################################################################

<urn:swrl:var#ca> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#t> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#i> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#m> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#a> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl:var#r> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasActionType ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#ca> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#t>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#classPredicate> :Recall ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#t>
                                                                ] ;
                                                      rdf:rest rdf:nil
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :RecallCorrectiveAction ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#ca>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasDeviceType ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#t>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#classPredicate> :ImplantableDevice ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#t>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :harRiskClass ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> :ClassIII
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :requiresImplantCard ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> "true"^^xsd:boolean
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :affectsDevice ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#i> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#d>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasManufacturer ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#d> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#m>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :addressesIncident ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#a> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#i>
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :actionIssuedBy ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#a> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#m>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasRisk ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl:var#i> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl:var#r>
