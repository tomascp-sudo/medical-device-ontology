#################################################################
#    Annotations
#################################################################

<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ActiveDevice> rdfs:comment "Medical device that uses a source of energy other than that generated by the human body or by gravity to perform its intended function."@en ;
                                                                            rdfs:label "Active Device"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ActiveImplant> rdfs:comment "Represents an active implant medical device type."@en ;
                                                                             rdfs:label "Active Implant"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassC> rdfs:label "ClassC"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassD> rdfs:comment "represents class D for in vitro diagnostic medical devices"@en ;
                                                                      rdfs:label "ClassD"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassIII> rdfs:comment "represents risk class III for medical devices"@en ;
                                                                        rdfs:label "ClassIII"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassIIa> rdfs:comment "Represents the Class IIa risk classification for medical devices."@en ;
                                                                        rdfs:label "ClassIIa"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ClassIIb> rdfs:comment "represents risk class IIb for medical devices"@en ;
                                                                        rdfs:label "ClassIIb"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Closed> rdfs:comment "Represents a closed status for a corrective action"@en ;
                                                                      rdfs:label "Closed"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ContaminationRisk> rdfs:comment "Represents a contamination risk for a risk Type"@en ;
                                                                                 rdfs:label "Contamination Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CybersecurityRisk> rdfs:comment "Risk of harm due to unauthorized access, interference, or data breach affecting the safety or performance of a medical device."@en ;
                                                                                 rdfs:label "Cybersecurity Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DeviceFailure> rdfs:comment "Failure or malfunction of a medical device that prevents it from performing its intended function as specified by the manufacturer"@en ;
                                                                             rdfs:label "Device Failure"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DevicePerformance> rdfs:comment "Measured behaviour or functional characteristics of a device under normal operating conditions, relative to its intended performance specifications"@en ;
                                                                                 rdfs:label "Device Performance"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DeviceSafety> rdfs:comment "Extent to which use of the device does not expose patients, users or others to unacceptable risk under normal conditions of use"@en ;
                                                                            rdfs:label "Device Safety"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DiagnosticError> rdfs:comment "A missed, delayed or incorrect diagnostic conclusion or communication that represents a missed opportunity for timely and accurate diagnosis"@en ;
                                                                               rdfs:label "Diagnostic Error"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#DiagnosticRisk> rdfs:comment "Represents a diagnostic  risk for a risk Type"@en ;
                                                                              rdfs:label "Diagnostic Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#IVDR> rdfs:comment "represents the In Vitro Diagnostic Medical Device Regulation applicable in the European Union"@en ;
                                                                    rdfs:label "IVDR"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ImplantableActiveDevice> rdfs:comment "Active implantable medical device intended to be introduced into the human body by surgical intervention and to remain in place after the procedure."@en ;
                                                                                       rdfs:label "Implantable Active Device"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ImplantableDevice> rdfs:comment "Medical device intended to be totally or partially introduced into the human body by surgical intervention and intended to remain in place after the procedure."@en ;
                                                                                 rdfs:label "Implantable Device"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InSituCorrection> rdfs:comment "Represents an in situ correction corrective action type."@en ;
                                                                                rdfs:label "In Situ Correction"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InVitroDiagnosticDevice> rdfs:comment "Medical device intended to be used in vitro for the examination of specimens derived from the human body to provide information for diagnostic, monitoring or compatibility purposes (IVDR)." ;
                                                                                       rdfs:label "In Vitro Diagnostic Device" .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InfectionRisk> rdfs:comment "Represents a infection risk for a risk Type"@en ;
                                                                             rdfs:label "Infection Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InjuryRisk> rdfs:comment "Risk of physical injury to a patient, user or other person resulting from the use or malfunction of a medical device."@en ;
                                                                          rdfs:label "Injury Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#InterferenceRisk> rdfs:comment "Represents a inference risk for a risk Type"@en ;
                                                                                rdfs:label "Interference Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#MDR> rdfs:comment "represents the Medical Device Regulation applicable in the European Union"@en ;
                                                                   rdfs:label "MDR"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#MalfunctionRisk> rdfs:comment "Risk arising when a medical device fails to perform its intended function according to the manufacturer's specifications."@en ;
                                                                               rdfs:label "Malfunction Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#MaterialRisk> rdfs:comment "Represents a material risk for a risk type"@en ;
                                                                            rdfs:label "Material Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#NearMissIncident> rdfs:comment "Incident that did not result in actual harm but had the potential to cause serious harm under slightly different circumstances."@en ;
                                                                                rdfs:label "Near Miss Incident"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Open> rdfs:comment "Represents a open status for a corrective action"@en ;
                                                                    rdfs:label "Open"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#PatientHarm> rdfs:comment "Physical or psychological injury, illness, or death experienced by a patient as a result of healthcare or device use, including harms caused or contributed to by device malfunction or misuse"@en ;
                                                                           rdfs:label "Patient Harm"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ProductQuality> rdfs:comment "Degree to which a product (device) conforms to specified design, manufacturing and regulatory requirements affecting safety, performance and traceability"@en ;
                                                                              rdfs:label "Product Quality"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#RadiationRisk> rdfs:comment "Represents a radiation risk for a risk Type"@en ;
                                                                             rdfs:label "Radiation Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Recall> rdfs:comment "Field safety corrective action consisting in the removal of a medical device from the market or from use due to safety or performance concerns."@en ;
                                                                      rdfs:label "Recall"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SafetyAlert> rdfs:comment "Communication issued by the manufacturer to inform users, distributors or competent authorities about a potential risk associated with a medical device."@en ;
                                                                           rdfs:label "Safety Alert"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SelfTestDevice> rdfs:comment "Medical device intended to be used by lay persons for self-testing outside a professional healthcare environment."@en ;
                                                                              rdfs:label "Self Test Device"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SeriousIncident> rdfs:comment "Incident that directly or indirectly led, might have led or might lead to the death of a patient, user or other person, or to a serious deterioration in their state of health, or to a serious public health threat." ;
                                                                               rdfs:label "Serious Incident" .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SingleUseDevice> rdfs:comment "Medical device intended to be used once only for a single patient and then discarded."@en ;
                                                                               rdfs:label "Single Use Device"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#SoftwareRisk> rdfs:comment "Risk related to software failures, algorithms, or cybersecurity issues in software-based medical devices."@en ;
                                                                            rdfs:label "Software Risk"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#UserNotice> rdfs:comment "Represents a user notice corrective action type."@en ;
                                                                          rdfs:label "User Notice"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#critical> rdfs:comment "Represents a critical severity level for a medical device risk"@en ;
                                                                        rdfs:label "critical"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#high> rdfs:comment "Represents a high probability level for a medical device risk"@en ;
                                                                    rdfs:label "high"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#low> rdfs:comment "Represents a low probability level for a medical device risk."@en ;
                                                                   rdfs:label "low"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#medium> rdfs:comment "Represents a medium probability level for a medical device risk."@en ;
                                                                      rdfs:label "medium"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#moderate> rdfs:comment "Represents a moderate severity level for a medical device risk"@en ;
                                                                        rdfs:label "moderate"@en .


<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#serious> rdfs:comment "Represents a serious severity level for a medical device risk"@en ;
                                                                       rdfs:label "serious"@en .


