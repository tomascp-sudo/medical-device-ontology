                                                                                                                                      owl:someValuesFrom <http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ImplantableDevice>
                                                                                                                                    ]
                                                                                                                                  ) ;
                                                                                                               rdf:type owl:Class
                                                                                                             ] ;
