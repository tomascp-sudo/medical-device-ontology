#################################################################
#    Annotations
#################################################################

:ActiveDevice rdfs:comment "Medical device that uses a source of energy other than that generated by the human body or by gravity to perform its intended function."@en ;
              rdfs:label "Active Device"@en .


:ActiveImplant rdfs:comment "Represents an active implant medical device type."@en ;
               rdfs:label "Active Implant"@en .


:ClassC rdfs:comment "represents a risk class C for in vitro diagnostic medical devices"@en ;
        rdfs:label "ClassC"@en .


:ClassD rdfs:comment "represents class D for in vitro diagnostic medical devices"@en ;
        rdfs:label "ClassD"@en .


:ClassIII rdfs:comment "represents risk class III for medical devices"@en ;
          rdfs:label "ClassIII"@en .


:ClassIIa rdfs:comment "Represents the Class IIa risk classification for medical devices."@en ;
          rdfs:label "ClassIIa"@en .


:ClassIIb rdfs:comment "represents risk class IIb for medical devices"@en ;
          rdfs:label "ClassIIb"@en .


:Closed rdfs:comment "Represents a closed status for a corrective action"@en ;
        rdfs:label "Closed"@en .


:ContaminationRisk rdfs:comment "Represents a contamination risk for a risk Type"@en ;
                   rdfs:label "Contamination Risk"@en .


:CybersecurityRisk rdfs:comment "Risk of harm due to unauthorized access, interference, or data breach affecting the safety or performance of a medical device."@en ;
                   rdfs:label "Cybersecurity Risk"@en .


:DeviceFailure rdfs:comment "Failure or malfunction of a medical device that prevents it from performing its intended function as specified by the manufacturer"@en ;
               rdfs:label "Device Failure"@en .


:DevicePerformance rdfs:comment "Measured behaviour or functional characteristics of a device under normal operating conditions, relative to its intended performance specifications"@en ;
                   rdfs:label "Device Performance"@en .


:DeviceSafety rdfs:comment "Extent to which use of the device does not expose patients, users or others to unacceptable risk under normal conditions of use"@en ;
              rdfs:label "Device Safety"@en .


:DiagnosticError rdfs:comment "A missed, delayed or incorrect diagnostic conclusion or communication that represents a missed opportunity for timely and accurate diagnosis"@en ;
                 rdfs:label "Diagnostic Error"@en .


:DiagnosticRisk rdfs:comment "Represents a diagnostic  risk for a risk Type"@en ;
                rdfs:label "Diagnostic Risk"@en .


:IVDR rdfs:comment "represents the In Vitro Diagnostic Medical Device Regulation applicable in the European Union"@en ;
      rdfs:label "IVDR"@en .


:ImplantableActiveDevice rdfs:comment "Active implantable medical device intended to be introduced into the human body by surgical intervention and to remain in place after the procedure."@en ;
                         rdfs:label "Implantable Active Device"@en .


:ImplantableDevice rdfs:comment "Medical device intended to be totally or partially introduced into the human body by surgical intervention and intended to remain in place after the procedure."@en ;
                   rdfs:label "Implantable Device"@en .


:InSituCorrection rdfs:comment "Represents an in situ correction corrective action type."@en ;
                  rdfs:label "In Situ Correction"@en .


:InVitroDiagnosticDevice rdfs:comment "Medical device intended to be used in vitro for the examination of specimens derived from the human body to provide information for diagnostic, monitoring or compatibility purposes (IVDR)." ;
                         rdfs:label "In Vitro Diagnostic Device" .


:InfectionRisk rdfs:comment "Represents a infection risk for a risk Type"@en ;
               rdfs:label "Infection Risk"@en .


:InjuryRisk rdfs:comment "Risk of physical injury to a patient, user or other person resulting from the use or malfunction of a medical device."@en ;
            rdfs:label "Injury Risk"@en .


:InterferenceRisk rdfs:comment "Represents a inference risk for a risk Type"@en ;
                  rdfs:label "Interference Risk"@en .


:MDR rdfs:comment "represents the Medical Device Regulation applicable in the European Union"@en ;
     rdfs:label "MDR"@en .


:MalfunctionRisk rdfs:comment "Risk arising when a medical device fails to perform its intended function according to the manufacturer's specifications."@en ;
                 rdfs:label "Malfunction Risk"@en .


:MaterialRisk rdfs:comment "Represents a material risk for a risk type"@en ;
              rdfs:label "Material Risk"@en .


:NearMissIncident rdfs:comment "Incident that did not result in actual harm but had the potential to cause serious harm under slightly different circumstances."@en ;
                  rdfs:label "Near Miss Incident"@en .


:Open rdfs:comment "Represents a open status for a corrective action"@en ;
      rdfs:label "Open"@en .


:PatientHarm rdfs:comment "Physical or psychological injury, illness, or death experienced by a patient as a result of healthcare or device use, including harms caused or contributed to by device malfunction or misuse"@en ;
             rdfs:label "Patient Harm"@en .


:ProductQuality rdfs:comment "Degree to which a product (device) conforms to specified design, manufacturing and regulatory requirements affecting safety, performance and traceability"@en ;
                rdfs:label "Product Quality"@en .


:RadiationRisk rdfs:comment "Represents a radiation risk for a risk Type"@en ;
               rdfs:label "Radiation Risk"@en .


:Recall rdfs:comment "Field safety corrective action consisting in the removal of a medical device from the market or from use due to safety or performance concerns."@en ;
        rdfs:label "Recall"@en .


:SafetyAlert rdfs:comment "Communication issued by the manufacturer to inform users, distributors or competent authorities about a potential risk associated with a medical device."@en ;
             rdfs:label "Safety Alert"@en .


:SelfTestDevice rdfs:comment "Medical device intended to be used by lay persons for self-testing outside a professional healthcare environment."@en ;
                rdfs:label "Self Test Device"@en .


:SeriousIncident rdfs:comment "Incident that directly or indirectly led, might have led or might lead to the death of a patient, user or other person, or to a serious deterioration in their state of health, or to a serious public health threat." ;
                 rdfs:label "Serious Incident" .


:SingleUseDevice rdfs:comment "Medical device intended to be used once only for a single patient and then discarded."@en ;
                 rdfs:label "Single Use Device"@en .


:SoftwareRisk rdfs:comment "Risk related to software failures, algorithms, or cybersecurity issues in software-based medical devices."@en ;
              rdfs:label "Software Risk"@en .


:UserNotice rdfs:comment "Represents a user notice corrective action type."@en ;
            rdfs:label "User Notice"@en .


:critical rdfs:comment "Represents a critical severity level for a medical device risk"@en ;
          rdfs:label "critical"@en .


:high rdfs:comment "Represents a high probability level for a medical device risk"@en ;
      rdfs:label "high"@en .


:low rdfs:comment "Represents a low probability level for a medical device risk."@en ;
     rdfs:label "low"@en .


:medium rdfs:comment "Represents a medium probability level for a medical device risk."@en ;
        rdfs:label "medium"@en .


:moderate rdfs:comment "Represents a moderate severity level for a medical device risk"@en ;
          rdfs:label "moderate"@en .


:serious rdfs:comment "Represents a serious severity level for a medical device risk"@en ;
         rdfs:label "serious"@en .


#################################################################
#    General axioms
#################################################################

[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf :CorrectiveAction
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :hasActionType ;
                    owl:hasValue :Recall
                  ]
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :fsca_id ;
                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:string
                  ]
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :action_date ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:date
                  ]
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :closure_date ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:date
                  ]
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :correctiveActionDescription ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:string
                  ]
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :countries_affected ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:string
                  ]
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :devices_affected ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:integer
                  ]
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :eudamed_fsca_ref ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:string
                  ]
] .


[ owl:intersectionOf ( :CorrectiveAction
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasActionType ;
                         owl:hasValue :Recall
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :scope ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:string
                  ]
] .


[ owl:intersectionOf ( :Device
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :harRiskClass ;
                         owl:someValuesFrom :ClassIII
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDeviceType ;
                         owl:someValuesFrom :ImplantableDevice
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf :Device
] .


[ owl:intersectionOf ( :Device
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :harRiskClass ;
                         owl:someValuesFrom :ClassIII
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDeviceType ;
                         owl:someValuesFrom :ImplantableDevice
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :harRiskClass ;
                    owl:someValuesFrom :ClassIII
                  ]
] .


[ owl:intersectionOf ( :Device
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :harRiskClass ;
                         owl:someValuesFrom :ClassIII
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDeviceType ;
                         owl:someValuesFrom :ImplantableDevice
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :hasDeviceType ;
                    owl:someValuesFrom :ImplantableDevice
                  ]
] .


[ owl:intersectionOf ( :Device
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :harRiskClass ;
                         owl:someValuesFrom :ClassIII
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDeviceType ;
                         owl:someValuesFrom :ImplantableDevice
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :device_id ;
                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:string
                  ]
] .


[ owl:intersectionOf ( :Device
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :harRiskClass ;
                         owl:someValuesFrom :ClassIII
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDeviceType ;
                         owl:someValuesFrom :ImplantableDevice
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :device_name ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:string
                  ]
] .


[ owl:intersectionOf ( :Device
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :harRiskClass ;
                         owl:someValuesFrom :ClassIII
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDeviceType ;
                         owl:someValuesFrom :ImplantableDevice
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :intended_purpose ;
                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                    owl:onDataRange xsd:string
                  ]
] .


[ owl:intersectionOf ( :Device
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :harRiskClass ;
                         owl:someValuesFrom :ClassIII
                       ]
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :hasDeviceType ;
                         owl:someValuesFrom :ImplantableDevice
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf [ rdf:type owl:Restriction ;
                    owl:onProperty :is_active ;
