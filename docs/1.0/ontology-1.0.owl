<?xml version="1.0"?>
<rdf:RDF xmlns="https://github.com/tomascp-sudo/medical-device-ontology/tree/main/docs/1.0/ontology.owl#"
     xml:base="https://github.com/tomascp-sudo/medical-device-ontology/tree/main/docs/1.0/ontology.owl"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:udi="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#udi:"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:udi1="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#udi:"
     xmlns:vann="https://github.com/tomascp-sudo/medical-device-ontology/blob/main/docs/ontology.owl#vann:"
     xmlns:schma="http://schema.org/"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:vann1="https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#vann:"
     xmlns:schma2="https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#schma:"
     xmlns:terms1="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology/abox#terms:"
     xmlns:terms2="https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#terms:"
     xmlns:terms3="https://tomascp-sudo.github.io/medical-device-ontology/1.0/ontology.owl"
     xmlns:ontology="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#"
     xmlns:medicalDeviceOntology="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#">
    <owl:Ontology rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl">
        <owl:versionIRI rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology-1.0.owl"/>
        <dc:contributor xml:lang="en">UOC - Universitat Oberta de Catalunya</dc:contributor>
        <dc:description>Ontology for representing medical devices, manufacturers, incidents, risks and corrective actions in regulatory surveillance scenarios.</dc:description>
        <dc:description>This ontology models relationships between devices, manufacturers, risks, incidents and field safety corrective actions (FSCA), enabling integrated regulatory surveillance within a single semantic framework.</dc:description>
        <dc:title xml:lang="en">EUDAMED-Inspired Medical Device Ontology</dc:title>
        <terms:abstract>This ontology provides a semantic model for high-risk medical devices and in vitro diagnostic devices, including their manufacturers, risk classes, incidents, and field safety corrective actions. It supports formal knowledge representation, reasoning, and interoperability in regulatory surveillance scenarios under MDR and IVDR frameworks.</terms:abstract>
        <terms:created>2026-04-26</terms:created>
        <terms:creator xml:lang="en">Diana Socola</terms:creator>
        <terms:creator xml:lang="en">Tomás Cuevas</terms:creator>
        <terms:issued xml:lang="en">2026-04-26</terms:issued>
        <terms:license>https://creativecommons.org/licenses/by-sa/4.0/</terms:license>
        <rdfs:comment>Ontology about medical devices, their classification, incidents, risks and corrective actions.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Devices Classification and Safety Ontology</rdfs:label>
        <owl:versionInfo>Version 1.0</owl:versionInfo>
        <schma2:includedInDataCatalog>This ontology is about medical devices, their classification, and the safety mechanisms associated with their use, including incidents and corrective actions.</schma2:includedInDataCatalog>
        <vann1:preferredNamespacePrefix>EUDAMED</vann1:preferredNamespacePrefix>
        <ontology:logo>https://upload.wikimedia.org/wikipedia/commons/thumb/8/8a/Small_logo_UOC.svg/3840px-Small_logo_UOC.svg.png</ontology:logo>
        <ontology:status>published</ontology:status>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
    </owl:Ontology>
    


