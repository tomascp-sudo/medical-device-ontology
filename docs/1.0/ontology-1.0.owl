    <owl:NamedIndividual rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#SoftwareRisk">
        <rdf:type rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#risk_type"/>
    </owl:NamedIndividual>
    


