    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ActiveDevice">
        <rdfs:comment xml:lang="en">Medical device that uses a source of energy other than that generated by the human body or by gravity to perform its intended function.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ActiveImplant">
        <rdfs:comment xml:lang="en">Represents an active implant medical device type.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Implant</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ClassC">
        <rdfs:comment xml:lang="en">represents a risk class C for in vitro diagnostic medical devices</rdfs:comment>
        <rdfs:label xml:lang="en">ClassC</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ClassD">
        <rdfs:comment xml:lang="en">represents class D for in vitro diagnostic medical devices</rdfs:comment>
        <rdfs:label xml:lang="en">ClassD</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ClassIII">
        <rdfs:comment xml:lang="en">represents risk class III for medical devices</rdfs:comment>
        <rdfs:label xml:lang="en">ClassIII</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ClassIIa">
        <rdfs:comment xml:lang="en">Represents the Class IIa risk classification for medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">ClassIIa</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ClassIIb">
        <rdfs:comment xml:lang="en">represents risk class IIb for medical devices</rdfs:comment>
        <rdfs:label xml:lang="en">ClassIIb</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#Closed">
        <rdfs:comment xml:lang="en">Represents a closed status for a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">Closed</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ContaminationRisk">
        <rdfs:comment xml:lang="en">Represents a contamination risk for a risk Type</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#CybersecurityRisk">
        <rdfs:comment xml:lang="en">Risk of harm due to unauthorized access, interference, or data breach affecting the safety or performance of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#DeviceFailure">
        <rdfs:comment xml:lang="en">Failure or malfunction of a medical device that prevents it from performing its intended function as specified by the manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">Device Failure</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#DevicePerformance">
        <rdfs:comment xml:lang="en">Measured behaviour or functional characteristics of a device under normal operating conditions, relative to its intended performance specifications</rdfs:comment>
        <rdfs:label xml:lang="en">Device Performance</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#DeviceSafety">
        <rdfs:comment xml:lang="en">Extent to which use of the device does not expose patients, users or others to unacceptable risk under normal conditions of use</rdfs:comment>
        <rdfs:label xml:lang="en">Device Safety</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#DiagnosticError">
        <rdfs:comment xml:lang="en">A missed, delayed or incorrect diagnostic conclusion or communication that represents a missed opportunity for timely and accurate diagnosis</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Error</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#DiagnosticRisk">
        <rdfs:comment xml:lang="en">Represents a diagnostic  risk for a risk Type</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#IVDR">
        <rdfs:comment xml:lang="en">represents the In Vitro Diagnostic Medical Device Regulation applicable in the European Union</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ImplantableActiveDevice">
        <rdfs:comment xml:lang="en">Active implantable medical device intended to be introduced into the human body by surgical intervention and to remain in place after the procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ImplantableDevice">
        <rdfs:comment xml:lang="en">Medical device intended to be totally or partially introduced into the human body by surgical intervention and intended to remain in place after the procedure.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#InSituCorrection">
        <rdfs:comment xml:lang="en">Represents an in situ correction corrective action type.</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#InVitroDiagnosticDevice">
        <rdfs:comment>Medical device intended to be used in vitro for the examination of specimens derived from the human body to provide information for diagnostic, monitoring or compatibility purposes (IVDR).</rdfs:comment>
        <rdfs:label>In Vitro Diagnostic Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#InfectionRisk">
        <rdfs:comment xml:lang="en">Represents a infection risk for a risk Type</rdfs:comment>
        <rdfs:label xml:lang="en">Infection Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#InjuryRisk">
        <rdfs:comment xml:lang="en">Risk of physical injury to a patient, user or other person resulting from the use or malfunction of a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#InterferenceRisk">
        <rdfs:comment xml:lang="en">Represents a inference risk for a risk Type</rdfs:comment>
        <rdfs:label xml:lang="en">Interference Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#MDR">
        <rdfs:comment xml:lang="en">represents the Medical Device Regulation applicable in the European Union</rdfs:comment>
        <rdfs:label xml:lang="en">MDR</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#MalfunctionRisk">
        <rdfs:comment xml:lang="en">Risk arising when a medical device fails to perform its intended function according to the manufacturer&apos;s specifications.</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#MaterialRisk">
        <rdfs:comment xml:lang="en">Represents a material risk for a risk type</rdfs:comment>
        <rdfs:label xml:lang="en">Material Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#NearMissIncident">
        <rdfs:comment xml:lang="en">Incident that did not result in actual harm but had the potential to cause serious harm under slightly different circumstances.</rdfs:comment>
        <rdfs:label xml:lang="en">Near Miss Incident</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#Open">
        <rdfs:comment xml:lang="en">Represents a open status for a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">Open</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#PatientHarm">
        <rdfs:comment xml:lang="en">Physical or psychological injury, illness, or death experienced by a patient as a result of healthcare or device use, including harms caused or contributed to by device malfunction or misuse</rdfs:comment>
        <rdfs:label xml:lang="en">Patient Harm</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#ProductQuality">
        <rdfs:comment xml:lang="en">Degree to which a product (device) conforms to specified design, manufacturing and regulatory requirements affecting safety, performance and traceability</rdfs:comment>
        <rdfs:label xml:lang="en">Product Quality</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#RadiationRisk">
        <rdfs:comment xml:lang="en">Represents a radiation risk for a risk Type</rdfs:comment>
        <rdfs:label xml:lang="en">Radiation Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#Recall">
        <rdfs:comment xml:lang="en">Field safety corrective action consisting in the removal of a medical device from the market or from use due to safety or performance concerns.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#SafetyAlert">
        <rdfs:comment xml:lang="en">Communication issued by the manufacturer to inform users, distributors or competent authorities about a potential risk associated with a medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#SelfTestDevice">
        <rdfs:comment xml:lang="en">Medical device intended to be used by lay persons for self-testing outside a professional healthcare environment.</rdfs:comment>
        <rdfs:label xml:lang="en">Self Test Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#SeriousIncident">
        <rdfs:comment>Incident that directly or indirectly led, might have led or might lead to the death of a patient, user or other person, or to a serious deterioration in their state of health, or to a serious public health threat.</rdfs:comment>
        <rdfs:label>Serious Incident</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#SingleUseDevice">
        <rdfs:comment xml:lang="en">Medical device intended to be used once only for a single patient and then discarded.</rdfs:comment>
        <rdfs:label xml:lang="en">Single Use Device</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#SoftwareRisk">
        <rdfs:comment xml:lang="en">Risk related to software failures, algorithms, or cybersecurity issues in software-based medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">Software Risk</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#UserNotice">
        <rdfs:comment xml:lang="en">Represents a user notice corrective action type.</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#critical">
        <rdfs:comment xml:lang="en">Represents a critical severity level for a medical device risk</rdfs:comment>
        <rdfs:label xml:lang="en">critical</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#high">
        <rdfs:comment xml:lang="en">Represents a high probability level for a medical device risk</rdfs:comment>
        <rdfs:label xml:lang="en">high</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#low">
        <rdfs:comment xml:lang="en">Represents a low probability level for a medical device risk.</rdfs:comment>
        <rdfs:label xml:lang="en">low</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#medium">
        <rdfs:comment xml:lang="en">Represents a medium probability level for a medical device risk.</rdfs:comment>
        <rdfs:label xml:lang="en">medium</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#moderate">
        <rdfs:comment xml:lang="en">Represents a moderate severity level for a medical device risk</rdfs:comment>
        <rdfs:label xml:lang="en">moderate</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#serious">
        <rdfs:comment xml:lang="en">Represents a serious severity level for a medical device risk</rdfs:comment>
        <rdfs:label xml:lang="en">serious</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#status">
        <rdfs:comment xml:lang="en">Represents a  status for a corrective action</rdfs:comment>
        <rdfs:label xml:lang="en">status</rdfs:label>
    </rdf:Description>
    


