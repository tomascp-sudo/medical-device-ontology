        <rdfs:range rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#Incident"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to the incident it addresses.</rdfs:comment>
        <rdfs:label xml:lang="en">addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


