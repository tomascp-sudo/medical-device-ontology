        <rdfs:range rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer  who was reported an incident</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


