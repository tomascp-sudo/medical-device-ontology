        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Specifies the date on which a corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">action_date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#authorization_number -->

