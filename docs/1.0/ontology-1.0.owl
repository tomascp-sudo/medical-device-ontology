    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#actionIssuedBy -->

    <owl:ObjectProperty rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#actionIssuedBy">
        <rdfs:domain rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#CorrectiveAction"/>
        <rdfs:range rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to the manufacturer that issued it</rdfs:comment>
        <rdfs:label xml:lang="en">actionIssuedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#addressesIncident -->

    <owl:ObjectProperty rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#addressesIncident">
