        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a corrective action has been taken for an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">corrective_action_taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#countries_affected -->

    <owl:DatatypeProperty rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#countries_affected">
