    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#reportedBy -->

    <owl:ObjectProperty rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#reportedBy">
