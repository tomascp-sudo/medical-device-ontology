    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#corrective_action_taken -->

    <owl:DatatypeProperty rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#corrective_action_taken">
