        <rdfs:range rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#status"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to its current status.</rdfs:comment>
        <rdfs:label xml:lang="en">has status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#hasType -->

    <owl:ObjectProperty rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#hasType">
