        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Specifies the date on which a corrective action was closed.</rdfs:comment>
        <rdfs:label xml:lang="en">closure_date</rdfs:label>
    </owl:DatatypeProperty>
    


