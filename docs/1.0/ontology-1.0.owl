     -->

    <owl:Class>
        <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#CorrectiveAction"/>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#hasActionType"/>
                <owl:hasValue rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#Recall"/>
            </owl:Restriction>
        </owl:intersectionOf>
        <rdfs:subClassOf rdf:resource="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#CorrectiveAction"/>
    </owl:Class>
