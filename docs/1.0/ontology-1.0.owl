        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Specifies the competent authority responsable for a manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">competent_authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#contact_email -->

