        <rdfs:label xml:lang="en">contact_email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#correctiveActionDescription -->

    <owl:DatatypeProperty rdf:about="https://tomascp-sudo.github.io/medicalDeviceOntology/1.0/ontology.owl#correctiveActionDescription">
