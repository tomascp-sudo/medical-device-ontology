  "@id" : "https://github.com/tomascp-sudo/medical-device-ontology/blob/main/docs/ontology.owl#vann:preferredNamespaceUri",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/elements/1.1/description" : [ {
    "@language" : "en",
    "@value" : "This ontology models relationships between devices, manufacturers, risks, incidents and field safety corrective actions (FSCA), enabling integrated regulatory surveillance within a single semantic framework."
  }, {
    "@value" : "This ontology provides a semantic representation of the medical devices domain, with a focus on device classification, safety, incidents, and corrective actions.\nIt is built using OWL (Web Ontology Language) to ensure logical consistency and interoperability, and it incorporates SWRL rules to support inference and reasoning.\n\nCore Concepts\n\nMedicalDevice:\nRepresents the general concept of a medical device. It is the superclass for more specific types such as ImplantableDevice or ActiveImplant.\nEach device can be described through properties such as name, manufacturer, classification, and device type.\n\nImplantableDevice / ActiveImplant:\nThese classes represent specific categories of medical devices, especially those that are placed inside the human body or require an energy source to function.\nThey are relevant for determining risk level and regulatory classification.\n\nRiskClass:\nRepresents the regulatory classification of the device, such as Class I, Class IIa, Class IIb, or Class III.\nThese classes are used to organize devices according to their level of risk and control requirements.\n\nCorrectiveAction:\nRepresents actions taken in response to incidents, defects, or safety issues related to a medical device.\nThese actions help model post-market surveillance and device safety procedures.\n\nProperties\n\nObject Properties:\nDefine relationships between instances of different classes. Examples include:\n\nhasClassification – connects a medical device to its regulatory class\nhasCorrectiveAction – connects a device or incident to a corrective action\nmanufacturedBy – connects a medical device to its manufacturer\n\nData Properties:\nDefine literal attributes. Examples include:\n\nhasName – assigns a name to a medical device\nhasModel – represents the commercial or technical model of the device\nhasSerialNumber – identifies a specific device instance\nhasRiskLevel – expresses the level of risk associated with a device\n\nIndividuals\nThe ontology contains a set of individuals representing example devices, classifications, manufacturers, and corrective actions.\nThese individuals allow reasoning engines to infer new facts and validate the consistency of the ontology.\n\nRules and Inference\nUsing SWRL rules, the ontology supports rule-based reasoning to infer classifications, detect relations between device types and risk classes, and support safety analysis.\nInside Protégé, the reasoner used was Pellet.\n\nExtensibility\nThe ontology is designed to be extensible and adaptable.\nNew classes, properties, and individuals can be incorporated as the domain evolves."
  } ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@language" : "en",
    "@value" : "Ontology for High-Risk Medical Devices and IVDs"
  }, {
    "@value" : "Medical Devices Classification and Safety Ontology"
  } ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@value" : "This ontology provides a semantic model for high-risk medical devices and in vitro diagnostic devices, including their manufacturers, risk classes, incidents, and field safety corrective actions. It supports formal knowledge representation, reasoning, and interoperability in regulatory surveillance scenarios under MDR and IVDR frameworks."
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@value" : "2026-04-18T14:30:00"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@language" : "en",
    "@value" : "Diana Socola"
  }, {
    "@language" : "en",
    "@value" : "Tomas Cuevas"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@value" : "https://creativecommons.org/licenses/by-sa/4.0/"
  } ],
  "http://schema.org/includedInDataCatalog" : [ {
    "@value" : "https://tomascp-sudo.github.io/medical-device-ontology/"
  } ],
  "http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#vann:preferredNamespacePrefix" : [ {
    "@value" : "https://tomascp-sudo.github.io/medical-device-ontology/ontology.owl#"
  }, {
    "@value" : "mdcso"
  } ],
  "http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology/abox#terms:abstract" : [ {
    "@value" : "The Medical Devices Classification and Safety Ontology provides a framework for modeling key concepts, entities, and relationships within the domain of medical devices.\nIt captures knowledge about device types, regulatory classes, manufacturers, and corrective actions.\nUsing OWL and SWRL, the ontology supports intelligent reasoning over safety-related data and facilitates interoperability, analysis, and querying within medical device information systems."
  } ],
  "http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology/abox#terms:created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-04-27"
  } ],
  "http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology/abox#terms:license" : [ {
    "@value" : "https://creativecommons.org/licenses/by-sa/4.0/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This ontology provides a formal and unified representation of the European catalogue of high-risk medical devices and in vitro diagnostic devices under the MDR and IVDR regulations."
  }, {
    "@value" : "This ontology is about medical devices, their classification, and the safety mechanisms associated with their use, including incidents and corrective actions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@value" : "The authors of this ontology have been:\n\nDiana Alejandrina Socola\n\nTomás Cuevas"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Ontology for High-Risk Medical Devices and IVDs"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://tomascp-sudo.github.io/medical-device-ontology/version/1.0/ontology.owl"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "This is V1.0"
  }, {
    "@value" : "Version 1.0"
  } ]
