    <rdf:Description rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#actionDate">
        <rdfs:comment xml:lang="en">Specifies the date on which a corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#actionDescription">
        <rdfs:comment xml:lang="en">Provides a textual description of the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">action description</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#closureDate">
        <rdfs:comment xml:lang="en">Specifies the date on which a corrective action was closed.</rdfs:comment>
        <rdfs:label xml:lang="en">closure date</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#correctiveActionTaken">
        <rdfs:comment xml:lang="en">Indicates whether a corrective action has been taken for an incident.</rdfs:comment>
        <rdfs:label xml:lang="en">corrective action taken</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#countriesAffected">
        <rdfs:comment xml:lang="en">Specifies the countries affected by a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">countries affected</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#countryReported">
        <rdfs:comment xml:lang="en">Specifies the country in which an incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">country reported</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#detectionDate">
        <rdfs:comment xml:lang="en">Specifies the date on which an incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="en">detection date</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#deviceName">
