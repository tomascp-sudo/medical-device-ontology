    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_001 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_001">
        <rdf:type rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction"/>
        <medicalDeviceOntology4:actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-01</medicalDeviceOntology4:actionDate>
        <medicalDeviceOntology4:actionDescription>Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0.</medicalDeviceOntology4:actionDescription>
        <medicalDeviceOntology4:correspondsToIncident rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident_INC_001"/>
        <medicalDeviceOntology4:countriesAffected>EU-wide</medicalDeviceOntology4:countriesAffected>
        <medicalDeviceOntology4:devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">850</medicalDeviceOntology4:devicesAffected>
        <medicalDeviceOntology4:eudamedFSCARef>EU-FSCA-2024-000001</medicalDeviceOntology4:eudamedFSCARef>
        <medicalDeviceOntology4:scope>All HeartMate 3 LVAD units implanted since 2020</medicalDeviceOntology4:scope>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_002 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_002">
        <rdf:type rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction"/>
        <medicalDeviceOntology4:actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-28</medicalDeviceOntology4:actionDate>
        <medicalDeviceOntology4:actionDescription>Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced.</medicalDeviceOntology4:actionDescription>
        <medicalDeviceOntology4:closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-31</medicalDeviceOntology4:closureDate>
        <medicalDeviceOntology4:correspondsToIncident rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident_INC_002"/>
        <medicalDeviceOntology4:countriesAffected>EU-wide + UK</medicalDeviceOntology4:countriesAffected>
        <medicalDeviceOntology4:devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1240</medicalDeviceOntology4:devicesAffected>
        <medicalDeviceOntology4:eudamedFSCARef>EU-FSCA-2024-000002</medicalDeviceOntology4:eudamedFSCARef>
        <medicalDeviceOntology4:scope>Micra AV lots manufactured between 2022-09 and 2023-03</medicalDeviceOntology4:scope>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_003 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_003">
        <rdf:type rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction"/>
        <medicalDeviceOntology4:actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-03-15</medicalDeviceOntology4:actionDate>
        <medicalDeviceOntology4:actionDescription>Enhanced deployment training and updated IFU for Portico valve implantation technique. New implantation checklist mandatory for all TAVI centres.</medicalDeviceOntology4:actionDescription>
        <medicalDeviceOntology4:closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-30</medicalDeviceOntology4:closureDate>
        <medicalDeviceOntology4:correspondsToIncident rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident_INC_003"/>
        <medicalDeviceOntology4:countriesAffected>EU-wide</medicalDeviceOntology4:countriesAffected>
        <medicalDeviceOntology4:devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">320</medicalDeviceOntology4:devicesAffected>
        <medicalDeviceOntology4:eudamedFSCARef>EU-FSCA-2024-000003</medicalDeviceOntology4:eudamedFSCARef>
        <medicalDeviceOntology4:scope>Portico THV sizes 23mm and 25mm from lots before 2023-11</medicalDeviceOntology4:scope>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_004 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_004">
        <rdf:type rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction"/>
        <medicalDeviceOntology4:actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-10</medicalDeviceOntology4:actionDate>
