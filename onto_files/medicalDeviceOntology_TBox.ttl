#################################################################
#    Classes
#################################################################

###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ActionType
medicalDeviceOntology:ActionType rdf:type owl:Class ;
                                 rdfs:comment "Represents the type of corrective action associated with a medical device incident."@en ;
                                 rdfs:label "Action type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ActiveDevice
medicalDeviceOntology:ActiveDevice rdf:type owl:Class ;
                                   rdfs:subClassOf medicalDeviceOntology:DeviceType ;
                                   rdfs:comment "Represents an active medical device type."@en ;
                                   rdfs:label "Active device"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#ActiveImplant
medicalDeviceOntology:ActiveImplant rdf:type owl:Class ;
                                    rdfs:subClassOf medicalDeviceOntology:DeviceType ;
                                    rdfs:comment "Represents an active implant medical device type."@en ;
                                    rdfs:label "Active implant"@en .


