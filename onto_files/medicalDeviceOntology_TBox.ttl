@prefix : <http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix medicalDeviceOntology: <http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#> .
@base <http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#> .

<http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#> rdf:type owl:Ontology ;
                                                                 owl:versionIRI <http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology/1.0> ;
                                                                 dc:description "This ontology models relationships between devices, manufacturers, risks, incidents and field safety corrective actions (FSCA), enabling integrated regulatory surveillance within a single semantic framework."@en ;
                                                                 dc:title "Ontology for High-Risk Medical Devices and IVDs"@en ;
                                                                 dcterms:abstract "This ontology provides a semantic model for high-risk medical devices and in vitro diagnostic devices, including their manufacturers, risk classes, incidents, and field safety corrective actions. It supports formal knowledge representation, reasoning, and interoperability in regulatory surveillance scenarios under MDR and IVDR frameworks." ;
                                                                 dcterms:created "2026-04-12"^^xsd:date ;
                                                                 dcterms:creator "Diana Socola"@en ,
                                                                                 "Tomas Cuevas"@en ;
                                                                 dcterms:license "https://creativecommons.org/licenses/by-sa/4.0/" ;
                                                                 medicalDeviceOntology:vann:preferredNamespacePrefix "mdcso" ;
                                                                 rdfs:comment "This ontology provides a formal and unified representation of the European catalogue of high-risk medical devices and in vitro diagnostic devices under the MDR and IVDR regulations."@en ;
                                                                 rdfs:label "Ontology for High-Risk Medical Devices and IVDs"@en ;
                                                                 owl:versionInfo "Version 1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/abstract
dcterms:abstract rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#license
medicalDeviceOntology:license rdf:type owl:AnnotationProperty .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#vann:preferredNamespacePrefix
medicalDeviceOntology:vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#addressesIncident
medicalDeviceOntology:addressesIncident rdf:type owl:ObjectProperty ;
                                        rdfs:domain medicalDeviceOntology:CorrectiveAction ;
                                        rdfs:range medicalDeviceOntology:Incident ;
                                        rdfs:comment "Relates a corrective action to the incident it addresses."@en ;
                                        rdfs:label "addresses incident"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#affectsDevice
medicalDeviceOntology:affectsDevice rdf:type owl:ObjectProperty ;
                                    rdfs:domain medicalDeviceOntology:Incident ;
                                    rdfs:range medicalDeviceOntology:Device ;
                                    rdfs:comment "Relates an incident to the device involved."@en ;
                                    rdfs:label "affects device"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasActionType
medicalDeviceOntology:hasActionType rdf:type owl:ObjectProperty ;
                                    rdfs:domain medicalDeviceOntology:CorrectiveAction ;
                                    rdfs:range medicalDeviceOntology:ActionType ;
                                    rdfs:comment "Relates a corrective action to its action type."@en ;
                                    rdfs:label "has action type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasDeviceType
medicalDeviceOntology:hasDeviceType rdf:type owl:ObjectProperty ;
                                    rdfs:domain medicalDeviceOntology:Device ;
                                    rdfs:range medicalDeviceOntology:DeviceType ;
                                    rdfs:comment "Relates a device to its device type."@en ;
                                    rdfs:label "has device type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasIncidentType
medicalDeviceOntology:hasIncidentType rdf:type owl:ObjectProperty ;
                                      rdfs:domain medicalDeviceOntology:Incident ;
                                      rdfs:range medicalDeviceOntology:IncidentType ;
                                      rdfs:comment "Relates an incident to its incident type."@en ;
                                      rdfs:label "has incident type"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasManufacturer
medicalDeviceOntology:hasManufacturer rdf:type owl:ObjectProperty ;
                                      rdfs:domain medicalDeviceOntology:Device ;
                                      rdfs:range medicalDeviceOntology:Manufacturer ;
                                      rdfs:comment "Relates a device to its manufacturer."@en ;
                                      rdfs:label "has manufacturer"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasProbability
medicalDeviceOntology:hasProbability rdf:type owl:ObjectProperty ;
                                     rdfs:domain medicalDeviceOntology:Risk ;
                                     rdfs:range medicalDeviceOntology:Probability ;
                                     rdfs:comment "Relates a risk to its probability level."@en ;
                                     rdfs:label "has probability"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasRegulatoryFramework
medicalDeviceOntology:hasRegulatoryFramework rdf:type owl:ObjectProperty ;
                                             rdfs:domain medicalDeviceOntology:Device ;
                                             rdfs:range medicalDeviceOntology:RegulatoryFramework ;
                                             rdfs:comment "Relates a device to its regulatory framework."@en ;
                                             rdfs:label "has regulatory framework"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasRisk
medicalDeviceOntology:hasRisk rdf:type owl:ObjectProperty ;
                              rdfs:domain medicalDeviceOntology:Incident ;
                              rdfs:range medicalDeviceOntology:Risk ;
                              rdfs:comment "Relates an incident to an identified risk"@en ;
                              rdfs:label "has risk"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasRiskClass
medicalDeviceOntology:hasRiskClass rdf:type owl:ObjectProperty ;
                                   rdfs:domain medicalDeviceOntology:Device ;
                                   rdfs:range medicalDeviceOntology:RiskClass ;
                                   rdfs:comment "Relates a device to its risk classification."@en ;
                                   rdfs:label "has risk class"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasSeverity
medicalDeviceOntology:hasSeverity rdf:type owl:ObjectProperty ;
                                  rdfs:domain medicalDeviceOntology:Risk ;
                                  rdfs:range medicalDeviceOntology:Severity ;
                                  rdfs:comment "Relates a risk to its severity level."@en ;
                                  rdfs:label "has severity"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#hasStatus
medicalDeviceOntology:hasStatus rdf:type owl:ObjectProperty ;
                                rdfs:domain medicalDeviceOntology:CorrectiveAction ;
                                rdfs:range medicalDeviceOntology:Status ;
                                rdfs:comment "Relates a corrective action to its current status."@en ;
                                rdfs:label "has status"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#actionDate
medicalDeviceOntology:actionDate rdf:type owl:DatatypeProperty ;
                                 rdfs:subPropertyOf medicalDeviceOntology:correctiveActionDataProperty ;
                                 rdfs:domain medicalDeviceOntology:CorrectiveAction ;
                                 rdfs:range xsd:date ;
                                 rdfs:comment "Specifies the date on which a corrective action was initiated."@en ;
                                 rdfs:label "action date"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#actionDescription
medicalDeviceOntology:actionDescription rdf:type owl:DatatypeProperty ;
                                        rdfs:subPropertyOf medicalDeviceOntology:correctiveActionDataProperty ;
                                        rdfs:domain medicalDeviceOntology:CorrectiveAction ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "Provides a textual description of the corrective action."@en ;
                                        rdfs:label "action description"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#authorizationNumber
medicalDeviceOntology:authorizationNumber rdf:type owl:DatatypeProperty ;
