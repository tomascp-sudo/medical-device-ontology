                                rdfs:domain medicalDeviceOntology:Risk ;
                                rdfs:range xsd:string ;
                                rdfs:comment "Specifies the IMDRF code assigned to a risk."@en ;
                                rdfs:label "IMDRF code"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#incidentDataProperty
medicalDeviceOntology:incidentDataProperty rdf:type owl:DatatypeProperty ;
                                           rdfs:domain medicalDeviceOntology:Incident ;
                                           rdfs:range rdfs:Literal ;
                                           rdfs:comment "Groups data properties used to describe incidents associated with medical devices."@en ;
                                           rdfs:label "incident data property"@en .


