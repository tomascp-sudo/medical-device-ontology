                                          rdfs:range xsd:string ;
                                          rdfs:comment "Specifies the authorization number assigned to a manufacturer."@en ;
                                          rdfs:label "authorization number"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#closureDate
medicalDeviceOntology:closureDate rdf:type owl:DatatypeProperty ;
