medicalDeviceOntology:competentAuthority rdf:type owl:DatatypeProperty ;
                                         rdfs:subPropertyOf medicalDeviceOntology:manufacturerDataProperty ;
                                         rdfs:domain medicalDeviceOntology:Manufacturer ;
                                         rdfs:range xsd:string ;
                                         rdfs:comment "Specifies the competent authority responsible for a manufacturer."@en ;
                                         rdfs:label "competent authority"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#contactEmail
medicalDeviceOntology:contactEmail rdf:type owl:DatatypeProperty ;
