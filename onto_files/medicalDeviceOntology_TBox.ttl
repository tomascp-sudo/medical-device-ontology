medicalDeviceOntology:incidentDescription rdf:type owl:DatatypeProperty ;
                                          rdfs:subPropertyOf medicalDeviceOntology:incidentDataProperty ;
                                          rdfs:domain medicalDeviceOntology:Incident ;
                                          rdfs:range xsd:string ;
                                          rdfs:comment "Provides a textual description of an incident."@en ;
                                          rdfs:label "incident description"@en .


