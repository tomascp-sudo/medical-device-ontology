[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate medicalDeviceOntology:hasDeviceType ;
                           swrl:argument1 <urn:swrl:var#d> ;
                           swrl:argument2 <urn:swrl:var#t>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:ClassAtom ;
                                      swrl:classPredicate medicalDeviceOntology:ImplantableDevice ;
                                      swrl:argument1 <urn:swrl:var#t>
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                 swrl:propertyPredicate medicalDeviceOntology:hasRiskClass ;
                                                 swrl:argument1 <urn:swrl:var#d> ;
                                                 swrl:argument2 <urn:swrl:var#c>
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:ClassAtom ;
                                                            swrl:classPredicate medicalDeviceOntology:ClassIII ;
                                                            swrl:argument1 <urn:swrl:var#c>
                                                          ] ;
                                                rdf:rest rdf:nil
                                              ]
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate medicalDeviceOntology:HighRiskImplantableDevice ;
                           swrl:argument1 <urn:swrl:var#d>
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate medicalDeviceOntology:hasRisk ;
                           swrl:argument1 <urn:swrl:var#i> ;
                           swrl:argument2 <urn:swrl:var#r>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                      swrl:propertyPredicate medicalDeviceOntology:hasProbability ;
                                      swrl:argument1 <urn:swrl:var#r> ;
                                      swrl:argument2 <urn:swrl:var#p>
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:ClassAtom ;
                                                 swrl:classPredicate medicalDeviceOntology:High ;
                                                 swrl:argument1 <urn:swrl:var#p>
                                               ] ;
                                     rdf:rest [ rdf:type swrl:AtomList ;
                                                rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                            swrl:propertyPredicate medicalDeviceOntology:hasSeverity ;
                                                            swrl:argument1 <urn:swrl:var#r> ;
                                                            swrl:argument2 <urn:swrl:var#s>
                                                          ] ;
                                                rdf:rest [ rdf:type swrl:AtomList ;
                                                           rdf:first [ rdf:type swrl:ClassAtom ;
                                                                       swrl:classPredicate medicalDeviceOntology:Serious ;
                                                                       swrl:argument1 <urn:swrl:var#s>
                                                                     ] ;
                                                           rdf:rest rdf:nil
                                                         ]
                                              ]
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate medicalDeviceOntology:HighRiskIncident ;
