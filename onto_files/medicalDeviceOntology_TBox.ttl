                                      rdfs:domain medicalDeviceOntology:CorrectiveAction ;
                                      rdfs:range xsd:integer ;
                                      rdfs:comment "Specifies the number of devices affected by a corrective action."@en ;
                                      rdfs:label "devices affected"@en .


