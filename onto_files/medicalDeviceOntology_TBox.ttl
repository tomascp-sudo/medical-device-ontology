                                   rdfs:domain medicalDeviceOntology:Manufacturer ;
                                   rdfs:range xsd:string ;
                                   rdfs:comment "Specifies the contact email address of a manufacturer."@en ;
                                   rdfs:label "contact email"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#correctiveActionDataProperty
medicalDeviceOntology:correctiveActionDataProperty rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain medicalDeviceOntology:CorrectiveAction ;
                                                   rdfs:range rdfs:Literal ;
                                                   rdfs:comment "Groups data properties used to describe corrective actions."@en ;
                                                   rdfs:label "corrective action data property"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#correctiveActionTaken
medicalDeviceOntology:correctiveActionTaken rdf:type owl:DatatypeProperty ;
