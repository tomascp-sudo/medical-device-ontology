                                            rdfs:domain medicalDeviceOntology:Incident ;
                                            rdfs:range xsd:boolean ;
                                            rdfs:comment "Indicates whether a corrective action has been taken for an incident."@en ;
                                            rdfs:label "corrective action taken"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#countriesAffected
medicalDeviceOntology:countriesAffected rdf:type owl:DatatypeProperty ;
                                        rdfs:subPropertyOf medicalDeviceOntology:correctiveActionDataProperty ;
                                        rdfs:domain medicalDeviceOntology:CorrectiveAction ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "Specifies the countries affected by a corrective action."@en ;
                                        rdfs:label "countries affected"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#country
medicalDeviceOntology:country rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf medicalDeviceOntology:manufacturerDataProperty ;
                              rdfs:domain medicalDeviceOntology:Manufacturer ;
                              rdfs:range xsd:string ;
                              rdfs:comment "Specifies the country where a manufacturer is located."@en ;
                              rdfs:label "country"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#countryReported
medicalDeviceOntology:countryReported rdf:type owl:DatatypeProperty ;
                                      rdfs:subPropertyOf medicalDeviceOntology:incidentDataProperty ;
                                      rdfs:domain medicalDeviceOntology:Incident ;
                                      rdfs:range xsd:string ;
                                      rdfs:comment "Specifies the country in which an incident was reported."@en ;
                                      rdfs:label "country reported"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#detectionDate
medicalDeviceOntology:detectionDate rdf:type owl:DatatypeProperty ;
                                    rdfs:subPropertyOf medicalDeviceOntology:incidentDataProperty ;
                                    rdfs:domain medicalDeviceOntology:Incident ;
                                    rdfs:range xsd:date ;
                                    rdfs:comment "Specifies the date on which an incident was detected."@en ;
                                    rdfs:label "detection date"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#deviceDataProperty
medicalDeviceOntology:deviceDataProperty rdf:type owl:DatatypeProperty ;
                                         rdfs:subPropertyOf owl:topDataProperty ;
                                         rdfs:domain medicalDeviceOntology:Device ;
                                         rdfs:range rdfs:Literal ;
                                         rdfs:comment "Groups data properties used to describe medical devices."@en ;
                                         rdfs:label "device data property" .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#deviceName
medicalDeviceOntology:deviceName rdf:type owl:DatatypeProperty ;
                                 rdfs:subPropertyOf medicalDeviceOntology:deviceDataProperty ;
