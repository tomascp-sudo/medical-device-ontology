                                 rdfs:domain medicalDeviceOntology:Manufacturer ;
                                 rdfs:range xsd:string ;
                                 rdfs:comment "Specifies the Single Registration Number assigned in EUDAMED."@en ;
                                 rdfs:label "EUDAMED SRN"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#eventDate
medicalDeviceOntology:eventDate rdf:type owl:DatatypeProperty ;
                                rdfs:subPropertyOf medicalDeviceOntology:incidentDataProperty ;
                                rdfs:domain medicalDeviceOntology:Incident ;
                                rdfs:range xsd:date ;
                                rdfs:comment "Specifies the date on which an incident occurred."@en ;
                                rdfs:label "event date"@en .


###  http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#imdrfCode
medicalDeviceOntology:imdrfCode rdf:type owl:DatatypeProperty ;
