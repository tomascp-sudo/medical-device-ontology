        <devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">620</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000009</eudamedFSCARef>
        <scope>All cobas e 801 immunoassay analysers</scope>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_010 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_010">
        <rdf:type rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-30</actionDate>
        <actionDescription>Immediate quarantine and replacement of affected reagent lots. Reflex testing protocol issued. All positive results from affected lots to be re-confirmed. New primer design covering BA.2.86 released.</actionDescription>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-31</closureDate>
        <correspondsToIncident rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident_INC_012"/>
        <countriesAffected>EU-wide + Norway + Iceland</countriesAffected>
        <devicesAffected>12500 tests</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000010</eudamedFSCARef>
        <scope>cobas SARS-CoV-2 RT-PCR reagent lot numbers CV-2024-0312 to CV-2024-0318</scope>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_011 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_011">
