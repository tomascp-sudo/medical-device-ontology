    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_008 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_008">
        <rdf:type rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-05</actionDate>
        <actionDescription>Software recall: mandatory update to version 2.2.0 resolving FiO2 calibration error. Biomedical engineers visited all affected units within 14 days. Field service documentation required.</actionDescription>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-15</closureDate>
        <correspondsToIncident rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident_INC_010"/>
        <countriesAffected>EU-wide</countriesAffected>
        <devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">180</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000008</eudamedFSCARef>
        <scope>ATERA ventilators with software version 2.1.3</scope>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_009 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_009">
        <rdf:type rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-20</actionDate>
        <actionDescription>Customer field notification regarding biotin interference in TSH assay. Updated sample preparation protocol and interference screening algorithm released via software update 4.1.2.</actionDescription>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-30</closureDate>
        <correspondsToIncident rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident_INC_011"/>
