    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_001 -->

    <owl:NamedIndividual rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_001">
        <rdf:type rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction"/>
        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-01</actionDate>
        <actionDescription>Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0.</actionDescription>
        <correspondsToIncident rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident_INC_001"/>
        <countriesAffected>EU-wide</countriesAffected>
        <devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">850</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000001</eudamedFSCARef>
        <scope>All HeartMate 3 LVAD units implanted since 2020</scope>
    </owl:NamedIndividual>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#CorrectiveAction_FSCA_002 -->

