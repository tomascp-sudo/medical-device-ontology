        <actionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-28</actionDate>
        <actionDescription>Voluntary recall of affected Micra AV lots due to premature battery depletion. Replacement units provided. 97% of affected devices successfully replaced.</actionDescription>
        <closureDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-31</closureDate>
        <correspondsToIncident rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDeviceOntology#Incident_INC_002"/>
        <countriesAffected>EU-wide + UK</countriesAffected>
        <devicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1240</devicesAffected>
        <eudamedFSCARef>EU-FSCA-2024-000002</eudamedFSCARef>
        <scope>Micra AV lots manufactured between 2022-09 and 2023-03</scope>
    </owl:NamedIndividual>
    


